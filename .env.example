# ─── App ──────────────────────────────────────────────
APP_NAME=myproject
DEBUG=false
SECRET_KEY=change_me_to_random_string_min_32_chars

# ─── Database ─────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=change_me_strong_password

# Полный URL (для SQLAlchemy / alembic)
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ─── Telegram Bot ─────────────────────────────────────
TG_BOT_TOKEN=
TG_ADMIN_CHAT_ID=      # твой chat_id для уведомлений

# ─── Webhook (прод) / Polling (локально) ──────────────
WEBHOOK_ENABLED=false
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook

# ─── WhatsApp (если нужно) ────────────────────────────
# WA_SESSION_PATH=/app/sessions/wa

# ─── Zalo (если нужно) ────────────────────────────────
# ZALO_APP_ID=
# ZALO_APP_SECRET=

# ─── X / Twitter (если нужно) ────────────────────────
# X_API_KEY=
# X_API_SECRET=
# X_BEARER_TOKEN=
